# Copy to env.sh and fill in for the real deployment, then `source env.sh` (or just run the scripts — they source it).
# env.sh is gitignored; this .example is the template.

# --- inference (data plane): where clients POST /openai/v1/* ---
export RELAY_BASE="http://127.0.0.1:8080"      # relay inference base, or your nginx LB
export RELAY_KEY="sk-wr-REPLACE_ME"            # a relay key whose policy allows $MODEL

# --- control plane: /metrics + /logs + /usage ---
export CTRL_BASE="http://127.0.0.1:8081"       # RELAY_CONTROL_PORT (default 8081)
export ADMIN_TOKEN="REPLACE_ME"                # RELAY_ADMIN_TOKEN

# --- the cheap model under test ---
# MUST be a model whose HostBinding adapter is `openai_responses` (so the request
# routes CC-inbound -> Responses-upstream, exercising the PR #332-#336 code paths).
# Keep it mini/nano so the token burn is trivial.
export MODEL="gpt-5-mini"                       # or gpt-5-nano
