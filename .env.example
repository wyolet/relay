# wyolet relay — example env. Copy to `.env` and fill in.
#
# Two modes:
#  (a) DEV-STACK MODE — `make dev` / `make smoke-up`. PG/CH/Jaeger live on dev-stack.
#      Run `pg-provision relay` to get a real RELAY_PG_DSN, then paste below.
#  (b) STANDALONE MODE — `docker compose up` (no -f), auto-loads override.yml.
#      Bundles its own PG/CH/Jaeger; use the second block's DSNs.

# -------- core --------
RELAY_CATALOG_BACKEND=pg
RELAY_STATE_BACKEND=redis
RELAY_EVENTLOG_BACKEND=clickhouse
RELAY_CONFIG_DIR=/config
RELAY_API_KEY=test-key
RELAY_ADMIN_TOKEN=admin-token
RELAY_ADMIN_USERNAME=aaliboyev
RELAY_ADMIN_PASSWORD=change-me
RELAY_MASTER_KEY=aZ5opEc3vkV8vUo5wgUJzUaAqjymt/aAm0RzzMlx/d4=
RELAY_CLUSTER_MODE=on
RELAY_CONTROL_ALLOW_ORIGINS=https://relay.wyolet.dev

# -------- ports (per PORTS.md, wyolet/relay block 5100-5119) --------
RELAY_LB_PORT=5100
RELAY_A_PORT=5101
RELAY_B_PORT=5102
RELAY_CONTROL_PORT=5103

# -------- image --------
RELAY_IMAGE=harbor.aliboyev.com/wyolet/relay:latest

# -------- (a) dev-stack mode --------
RELAY_PG_DSN=postgres://relay:CHANGE_ME@dev-stack.wyolet.dev:5432/relay?sslmode=disable
RELAY_CH_DSN=clickhouse://default:@dev-stack.wyolet.dev:9000/relay
RELAY_REDIS_ADDR=valkey:6379
RELAY_OTLP_ENDPOINT=dev-stack.wyolet.dev:4317

# -------- (b) standalone mode (uncomment, comment out (a)) --------
# RELAY_PG_DSN=postgres://relay:relay@postgres:5432/relay?sslmode=disable
# RELAY_CH_DSN=clickhouse://relay:relay@clickhouse:9000/relay
# RELAY_REDIS_ADDR=valkey:6379
# RELAY_OTLP_ENDPOINT=jaeger:4317

# -------- testing --------
OPENAI_KEY_TEST=test-value-1234
LOADTEST_ANON_KEY=fake-anon-1234
