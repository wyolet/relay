# wyolet relay — example env. Copy to `.env` and fill in.
#
# Two modes:
#  (a) STANDALONE MODE (default) — `docker compose up` (no -f) auto-loads
#      override.yml, which bundles its own Postgres/ClickHouse/Valkey/Jaeger.
#      The DSNs below point at those bundled services.
#  (b) EXTERNAL MODE — point the DSNs at your own managed PG/CH/Redis/OTLP
#      (see the commented block at the bottom).

# -------- core --------
RELAY_CATALOG_BACKEND=pg
RELAY_STATE_BACKEND=redis
RELAY_EVENTLOG_BACKEND=clickhouse
RELAY_CONFIG_DIR=/config
RELAY_API_KEY=test-key
RELAY_ADMIN_TOKEN=admin-token
RELAY_ADMIN_PASSWORD=change-me
# REQUIRED — master key for encrypting stored credentials (AES-256).
# Generate your OWN; never reuse a value copied from anywhere public:
#   openssl rand -base64 32
RELAY_MASTER_KEY=
RELAY_CLUSTER_MODE=on
RELAY_CONTROL_ALLOW_ORIGINS=http://localhost:5100

# -------- ports --------
RELAY_LB_PORT=5100
RELAY_A_PORT=5101
RELAY_B_PORT=5102
RELAY_CONTROL_PORT=5103

# -------- image --------
RELAY_IMAGE=ghcr.io/wyolet/relay:latest

# -------- (a) standalone mode (default — bundled services) --------
RELAY_PG_DSN=postgres://relay:relay@postgres:5432/relay?sslmode=disable
RELAY_CH_DSN=clickhouse://relay:relay@clickhouse:9000/relay
RELAY_REDIS_ADDR=valkey:6379
RELAY_OTLP_ENDPOINT=jaeger:4317

# -------- (b) external mode (uncomment + point at your own services) --------
# RELAY_PG_DSN=postgres://USER:PASSWORD@your-postgres-host:5432/relay?sslmode=require
# RELAY_CH_DSN=clickhouse://USER:PASSWORD@your-clickhouse-host:9000/relay
# RELAY_REDIS_ADDR=your-redis-host:6379
# RELAY_OTLP_ENDPOINT=your-otel-collector:4317

# -------- testing --------
OPENAI_KEY_TEST=test-value-1234
LOADTEST_ANON_KEY=fake-anon-1234
